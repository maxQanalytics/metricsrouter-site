---
const contributors = [
  'Djimmer Smits',
  'Goran Mandir',
  'Isabel Quint',
  'Jeroen de Vries',
  'Paul van Vulpen',
  'Philip Boontje',
  'Riccardo Luca Fabrizi',
];
---

<section class="py-20 lg:py-28 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="fade-in mb-10">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#0D5F52] mb-4">The Contributors</p>
      <p class="text-gray-600 leading-relaxed max-w-2xl">
        The following citizens have contributed to the business plan with their domain expertise, critical mind and invigorating energy, in alphabetic order:
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {contributors.map((name) => (
        <div class="fade-in flex items-center gap-3 p-4 rounded-xl border border-gray-100 bg-gray-50">
          <div class="w-9 h-9 rounded-full bg-[#0D5F52] text-white text-sm font-semibold flex items-center justify-center shrink-0">
            {name.charAt(0)}
          </div>
          <span class="text-sm font-medium text-gray-800">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
