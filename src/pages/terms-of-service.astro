---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Service | Metricsrouter" description="Terms and conditions for the use of the Metricsrouter website.">
  <Nav />
  <main class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Terms of Service</h1>
      <p class="text-sm text-gray-400 mb-12">Last updated: 2023</p>

      <div class="prose prose-gray max-w-none space-y-8 text-gray-600 leading-relaxed">

        <p>These terms and conditions outline the rules and regulations for the use of Metricsrouter's website, located at metricsrouter.com. By accessing this website we assume you accept these terms and conditions. Do not continue to use the website if you do not agree to take all of the terms and conditions stated on this page.</p>

        <section>
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Terminology</h2>
          <p>The following terminology applies to these Terms and Conditions, Privacy Statement and Disclaimer Notice and all Agreements: "Client", "You" and "Your" refers to you, the person logging on this website and compliant to Metricsrouter's terms and conditions. "The Company", "Ourselves", "We", "Our" and "Us" refers to our Company. "Party", "Parties", or "Us" refers to both the Client and ourselves. All terms refer to the offer, acceptance and consideration of payment necessary to undertake the process of our assistance to the Client in the most appropriate manner for the express purpose of meeting the Client's needs in respect of provision of the Company's stated services, in accordance with and subject to, prevailing law of Netherlands.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Cookies</h2>
